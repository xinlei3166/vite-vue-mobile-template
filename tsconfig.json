{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "noImplicitAny": true,
    "lib": ["esnext", "dom"],
    "types": ["vite/client", "node"]
    // "ignoreDeprecations": "6.0",
    //    "baseUrl": ".",
    //    "paths": {
    //      "@/*": ["./src/*"]
    //    }
  },
  "include": ["packages/**/*.ts", "packages/**/*.d.ts", "packages/**/*.tsx", "packages/**/*.vue"],
  "exclude": ["node_modules"]
}
